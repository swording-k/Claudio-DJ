{
  "$schema": "https://schema.tauri.studio/config/2",
  "productName": "Claudio DJ",
  "version": "0.1.0",
  "identifier": "com.claudiodj.app",
  "frontendDist": "../dist",
  "devUrl": "http://localhost:8080",
  "beforeDevCommand": "npm run dev",
  "beforeBuildCommand": "npm run build",
  "app": {
    "windows": [
      {
        "title": "Claudio DJ",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}