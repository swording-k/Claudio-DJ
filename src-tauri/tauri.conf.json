{
  "$schema": "https://schema.tauri.studio/config/2",
  "productName": "Claudio",
  "version": "0.1.3",
  "identifier": "com.claudiodj.app",
  "build": {
    "frontendDist": "../src-web/dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "title": "Claudio",
        "width": 420,
        "height": 560,
        "minWidth": 380,
        "minHeight": 560,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}